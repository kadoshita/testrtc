{
  "name": "TestRTC",
  "description": "Collection of tests and tools to help diagnose WebRTC systems.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git://github.com/webrtc/testrtc"
  },
  "license": "BSD-3-Clause",
  "authors": [
    "The WebRTC project authors (http://www.webrtc.org/)"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/kv-asset-handler": "^0.5.0",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "webrtc-adapter": "^9.0.5",
    "wrangler": "^4.90.0"
  }
}
